---
import Logo from './Logo.astro';

const columns = [
  {
    title: 'Product',
    links: [
      { label: 'Features', href: '/product' },
      { label: 'Pricing', href: '/pricing' },
      { label: 'Snowflake Integration', href: '/snowflake' },
    ],
  },
  {
    title: 'Company',
    links: [
      { label: 'About', href: '/about' },
      { label: 'Contact', href: '/contact' },
    ],
  },
  {
    title: 'Legal',
    links: [
      { label: 'Privacy Policy', href: '/privacy' },
      { label: 'Terms of Service', href: '/terms' },
    ],
  },
  {
    title: 'Connect',
    links: [
      { label: 'Snowflake Marketplace', href: '#' },
      { label: 'GitHub', href: '#' },
    ],
  },
];

const year = new Date().getFullYear();
---

<footer class="bg-dark-stone text-white">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid grid-cols-2 md-nav:grid-cols-5 gap-8">
      {/* Logo + tagline */}
      <div class="col-span-2 md-nav:col-span-1">
        <Logo variant="orange" />
        <p class="mt-4 text-sm text-white/60 leading-relaxed">
          Automated data quality monitoring for Snowflake.
        </p>
      </div>

      {/* Nav columns */}
      {columns.map(({ title, links }) => (
        <div>
          <h4 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">
            {title}
          </h4>
          <ul class="list-none m-0 p-0 space-y-2">
            {links.map(({ label, href }) => (
              <li>
                <a
                  href={href}
                  class="text-white/60 no-underline text-sm hover:text-white transition-colors"
                >
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    {/* Copyright */}
    <div class="mt-12 pt-8 border-t border-white/10 text-center text-sm text-white/40">
      &copy; {year} DataShepherd. All rights reserved.
    </div>
  </div>
</footer>
