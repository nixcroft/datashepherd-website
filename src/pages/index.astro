---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="DataShepherd — Data Quality for Snowflake">
  <main class="max-w-7xl mx-auto px-6 py-24">
    <h1 class="text-hero font-bold text-shepherd-blue leading-tight">
      Trust your data.
    </h1>
    <p class="mt-6 text-lg text-dark-stone/80 max-w-2xl">
      Automated data quality monitoring for Snowflake. Detect anomalies,
      enforce rules, and gain confidence in every row.
    </p>
    <div class="mt-10 flex gap-4">
      <a
        href="#"
        class="inline-flex items-center px-6 py-3 bg-orange text-white font-semibold rounded-lg no-underline hover:brightness-110 transition"
      >
        Get Started
      </a>
      <a
        href="#"
        class="inline-flex items-center px-6 py-3 border-2 border-shepherd-blue text-shepherd-blue font-semibold rounded-lg no-underline hover:bg-shepherd-blue hover:text-white transition"
      >
        Learn More
      </a>
    </div>
  </main>
</BaseLayout>
