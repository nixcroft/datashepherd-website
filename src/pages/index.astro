---
import PageLayout from '../layouts/PageLayout.astro';
import Button from '../components/Button.astro';
---

<PageLayout title="DataShepherd — Data Quality for Snowflake">
  <section class="max-w-7xl mx-auto px-6 py-24">
    <h1 class="text-hero font-bold text-shepherd-blue leading-tight">
      Trust your data.
    </h1>
    <p class="mt-6 text-lg text-dark-stone/80 max-w-2xl">
      Automated data quality monitoring for Snowflake. Detect anomalies,
      enforce rules, and gain confidence in every row.
    </p>
    <div class="mt-10 flex gap-4">
      <Button variant="primary" href="/get-started">Get Started</Button>
      <Button variant="outline" href="/product">Learn More</Button>
    </div>
  </section>
</PageLayout>
